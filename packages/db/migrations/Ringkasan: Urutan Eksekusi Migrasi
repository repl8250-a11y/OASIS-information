To apply all migrations in the correct order, run the following command:

#!/bin/bash

MIGRATIONS_DIR="packages/db/migrations"

for migration in \
  001_create_users_tables.sql \
  002_create_organizations_tables.sql \
  003_create_papers_tables.sql \
  004_create_collections_tables.sql \
  005_create_collaboration_tables.sql \
  006_create_search_tables.sql \
  007_create_analysis_tables.sql \
  008_create_copilot_tables.sql \
  009_create_knowledge_graph_tables.sql \
  010_create_access_control_tables.sql \
  011_create_system_tables.sql \
  012_add_foreign_keys.sql \
  013_add_partitioning.sql \
  014_add_performance_indexes.sql
do
  echo "Executing: $migration"
  psql -U postgres -d researchos -f "$MIGRATIONS_DIR/$migration"
  if [ $? -eq 0 ]; then
    echo "вњ“ $migration completed"
  else
    echo "вњ— $migration failed"
    exit 1
  fi
done

echo "All migrations completed successfully!"

